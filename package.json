{
  "name": "complykit-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "check-bundle-size": "node scripts/check-bundle-size.mjs",
    "cf:build": "opennextjs-cloudflare build && npm run check-bundle-size",
    "preview": "opennextjs-cloudflare build && npm run check-bundle-size && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && npm run check-bundle-size && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && npm run check-bundle-size && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "wrangler": "^4.110.0"
  }
}
