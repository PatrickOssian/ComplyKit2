NEXTJS_ENV=development

# Neon Postgres connection string (pooled endpoint).
DATABASE_URL="postgres://..."
# Random secret used to sign Better Auth session tokens — generate with
# `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`.
AUTH_SECRET="..."
# Base URL Better Auth uses to build callback/redirect links.
BETTER_AUTH_URL="http://localhost:3000"
